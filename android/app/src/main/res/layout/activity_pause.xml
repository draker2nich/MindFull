<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F0"
    android:padding="24dp">

    <!-- Заголовок -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Сделай паузу"
        android:textSize="24sp"
        android:textColor="#2D3A3A"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Дыши и подумай, зачем ты это открываешь"
        android:textSize="14sp"
        android:textColor="#6B7B7B"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Дыхательный круг -->
    <View
        android:id="@+id/breathCircle"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/breath_circle_bg"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintBottom_toTopOf="@id/tvBreathHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Таймер внутри круга (наложен поверх) -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="60"
        android:textSize="40sp"
        android:textColor="#2D3A3A"
        android:fontFamily="sans-serif-light"
        app:layout_constraintTop_toTopOf="@id/breathCircle"
        app:layout_constraintBottom_toBottomOf="@id/breathCircle"
        app:layout_constraintStart_toStartOf="@id/breathCircle"
        app:layout_constraintEnd_toEndOf="@id/breathCircle" />

    <!-- Подсказка дыхания -->
    <TextView
        android:id="@+id/tvBreathHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Вдох..."
        android:textSize="16sp"
        android:textColor="#6B9B8A"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/breathCircle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Поле заметки -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilNote"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:hint="Зачем ты хочешь это открыть? (необязательно)"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:counterEnabled="true"
        app:counterMaxLength="200"
        app:layout_constraintTop_toBottomOf="@id/tvBreathHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLength="200"
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:textSize="14sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Кнопка перехода -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProceed"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Подожди..."
        android:textSize="16sp"
        android:enabled="false"
        android:layout_marginBottom="32dp"
        app:cornerRadius="16dp"
        app:backgroundTint="#6B9B8A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>