<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pause_bg"
    android:fitsSystemWindows="true">

    <!-- Верхний блок: заголовок + subtitle -->
    <LinearLayout
        android:id="@+id/headerBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="56dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сделай паузу"
            android:textSize="28sp"
            android:textColor="@color/pause_text_primary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Дыши и подумай"
            android:textSize="15sp"
            android:textColor="@color/pause_text_secondary"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Дыхательный круг с таймером внутри -->
    <FrameLayout
        android:id="@+id/breathContainer"
        android:layout_width="220dp"
        android:layout_height="220dp"
        app:layout_constraintTop_toBottomOf="@id/headerBlock"
        app:layout_constraintBottom_toTopOf="@id/noteBlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.35">

        <!-- Внешнее свечение (большой полупрозрачный круг) -->
        <View
            android:id="@+id/breathGlow"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:background="@drawable/breath_glow_bg" />

        <!-- Основной круг -->
        <View
            android:id="@+id/breathCircle"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:background="@drawable/breath_circle_bg" />

        <!-- Таймер -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="60"
            android:textSize="48sp"
            android:textColor="@color/pause_text_primary"
            android:fontFamily="sans-serif-light" />

    </FrameLayout>

    <!-- Подсказка дыхания -->
    <TextView
        android:id="@+id/tvBreathHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Вдох..."
        android:textSize="17sp"
        android:textColor="@color/pause_accent"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/breathContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Блок заметки -->
    <LinearLayout
        android:id="@+id/noteBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="28dp"
        android:paddingHorizontal="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvBreathHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnProceed"
        app:layout_constraintVertical_bias="0.0">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Зачем ты хочешь это открыть?"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@android:color/transparent"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeColor="@color/pause_accent"
            app:hintTextColor="@color/pause_text_secondary"
            app:counterEnabled="true"
            app:counterMaxLength="200"
            app:helperText="Необязательно · сохранится автоматически"
            app:helperTextEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLength="200"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:textSize="15sp"
                android:textColor="@color/pause_text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Кнопка перехода -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProceed"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="36dp"
        android:text="Подожди..."
        android:textSize="16sp"
        android:enabled="false"
        app:cornerRadius="16dp"
        app:backgroundTint="@color/pause_accent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>